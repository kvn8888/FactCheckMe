# Core app mode
VITE_DB_PROVIDER=supabase
VITE_TRANSCRIPTION_PROVIDER=elevenlabs

# Database client configuration (provider-agnostic aliases)
VITE_BACKEND_DB_URL=https://your-project.supabase.co
VITE_BACKEND_DB_PUBLISHABLE_KEY=your_supabase_anon_key

# Backwards-compatible Supabase keys (still supported)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Azure realtime transcription (if VITE_TRANSCRIPTION_PROVIDER=azure)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=en-US

# Azure database (if VITE_DB_PROVIDER=azure)
AZURE_DB_CONNECTION_STRING=Server=tcp:server.database.windows.net,1433;Database=factcheckme;...

# Server-side secrets (set in backend host/Supabase edge functions)
# ELEVENLABS_API_KEY=...
# GEMINI_API_KEY=...
# HYPERSPELL_API_KEY=...
